<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h2 class="text-3xl font-extrabold text-white">Kelola Menu Seafood</h2>
      <p class="text-slate-400 text-sm mt-1">Tambah, perbarui status, atau hapus menu hidangan restoran Anda.</p>
    </div>
    <a 
      href="/admin/menus/create"
      class="bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30 transition flex items-center gap-2"
    >
      <i class="fa-solid fa-plus-circle"></i> Tambah Menu Baru
    </a>
  </div>

  <!-- Messages -->
  <%- include('../../partials/alerts') %>

  <!-- Menu List Card -->
  <div class="glass-card rounded-2xl overflow-hidden border border-slate-800">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-sm">
        <thead>
          <tr class="bg-dark-800 border-b border-slate-800 text-slate-400 text-xs font-semibold uppercase tracking-wider">
            <th class="px-6 py-4">Foto</th>
            <th class="px-6 py-4">Nama Menu</th>
            <th class="px-6 py-4">Kategori</th>
            <th class="px-6 py-4">Harga / Satuan</th>
            <th class="px-6 py-4">Status Ketersediaan</th>
            <th class="px-6 py-4 text-right">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/80">
          <% if (menus && menus.length > 0) { %>
            <% menus.forEach(menu => { %>
              <tr class="hover:bg-dark-800/30 transition-colors">
                
                <!-- Image -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="w-16 h-12 rounded-lg overflow-hidden bg-dark-800 border border-slate-700/40">
                    <img 
                      src="<%= menu.image %>" 
                      alt="<%= menu.name %>" 
                      class="w-full h-full object-cover"
                      onerror="this.src='/images/default-logo.png'"
                    />
                  </div>
                </td>

                <!-- Name & Description -->
                <td class="px-6 py-4">
                  <div class="font-bold text-white text-sm"><%= menu.name %></div>
                  <div class="text-slate-400 text-xs truncate max-w-[250px] mt-0.5"><%= menu.description || 'Tidak ada deskripsi.' %></div>
                </td>

                <!-- Category -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="capitalize text-xs font-semibold px-2.5 py-0.5 bg-dark-700 text-slate-300 rounded-full">
                    <%= menu.category %>
                  </span>
                </td>

                <!-- Price -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="font-extrabold text-brand-500">
                    Rp <%= parseFloat(menu.price).toLocaleString('id-ID') %>
                    <span class="text-slate-500 text-xs font-normal">/<%= menu.priceType %></span>
                  </div>
                </td>

                <!-- Availability status -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (menu.isAvailable) { %>
                    <span class="text-[10px] font-bold text-emerald-400 px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/25 rounded-full">
                      <i class="fa-solid fa-circle text-[6px] mr-1.5 align-middle"></i>Tersedia
                    </span>
                  <% } else { %>
                    <span class="text-[10px] font-bold text-red-400 px-2.5 py-1 bg-red-500/10 border border-red-500/25 rounded-full">
                      <i class="fa-solid fa-circle text-[6px] mr-1.5 align-middle"></i>Habis
                    </span>
                  <% } %>
                </td>

                <!-- Actions -->
                <td class="px-6 py-4 text-right whitespace-nowrap">
                  <div class="inline-flex gap-2">
                    <!-- Edit Link -->
                    <a 
                      href="/admin/menus/<%= menu.id %>/edit" 
                      class="bg-dark-900 border border-slate-700/60 hover:border-slate-500 text-slate-300 p-2 rounded-lg transition"
                    >
                      <i class="fa-solid fa-pen-to-square text-xs"></i>
                    </a>

                    <!-- Delete Form -->
                    <form 
                      action="/admin/menus/<%= menu.id %>/delete" 
                      method="POST" 
                      class="inline"
                      onsubmit="return confirm('Apakah Anda yakin ingin menghapus menu ini?')"
                    >
                      <button 
                        type="submit" 
                        class="bg-dark-900 border border-slate-700/60 hover:bg-red-500/10 text-slate-400 hover:text-red-400 p-2 rounded-lg transition cursor-pointer"
                      >
                        <i class="fa-solid fa-trash-can text-xs"></i>
                      </button>
                    </form>
                  </div>
                </td>

              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-slate-500">
                <i class="fa-solid fa-utensils text-3xl mb-2 text-slate-600"></i>
                <p class="font-semibold text-sm">Tidak ada menu masakan</p>
                <p class="text-xs mt-1 text-slate-500">Klik "Tambah Menu Baru" untuk memasukkan item pertama.</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<%- include('../../partials/footer') %>
