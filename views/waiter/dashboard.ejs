<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div 
  x-data="{ 
    orders: <%= JSON.stringify(orders) %>,
    activeFilter: '<%= activeFilter %>',
    qrisModalOpen: false,
    qrisOrder: null,
    qrisQrUrl: '',
    qrisLoading: false,
    qrisError: '',
    
    async openQrisModal(orderId) {
      this.qrisModalOpen = true;
      this.qrisLoading = true;
      this.qrisError = '';
      this.qrisOrder = null;
      this.qrisQrUrl = '';
      
      try {
        const res = await fetch('/api/qris/generate/' + orderId);
        const data = await res.json();
        if (data.success) {
          this.qrisOrder = data.order;
          this.qrisQrUrl = data.qrisQrUrl;
        } else {
          this.qrisError = data.error;
        }
      } catch (err) {
        this.qrisError = 'Gagal memuat QRIS dari server.';
      } finally {
        this.qrisLoading = false;
      }
    },
    
    get filteredOrders() {
      if (this.activeFilter === 'active') {
        return this.orders.filter(o => ['pending', 'processing', 'completed'].includes(o.status));
      }
      return this.orders.filter(o => o.status === this.activeFilter);
    },

    async pollOrders() {
      try {
        const res = await fetch('/api/orders?role=waiter');
        const data = await res.json();
        if (data.success) {
          this.orders = data.orders;
        }
      } catch (err) {
        console.error('Failed to poll waiter orders:', err);
      }
    },

    init() {
      // Auto-poll orders for waiter every 10 seconds
      setInterval(() => this.pollOrders(), 10000);
    }
  }"
  class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow space-y-6"
>

  <!-- Title -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h2 class="text-2xl font-black text-white"><i class="fa-solid fa-bell-concierge text-brand-500 mr-2"></i>Antrean Dapur & Pelayanan</h2>
      <p class="text-slate-400 text-xs mt-1">Daftar pesanan aktif untuk dimasak dapur atau disajikan ke pelanggan.</p>
    </div>
    
    <div class="flex items-center gap-2 w-full sm:w-auto">
      <a 
        href="/"
        class="flex-1 sm:flex-none bg-brand-600 hover:bg-brand-500 text-white px-4 py-2.5 rounded-xl text-xs font-semibold flex items-center justify-center gap-2 transition shadow-lg shadow-brand-500/20 cursor-pointer"
      >
        <i class="fa-solid fa-cart-plus"></i> Input Pesanan (Katalog)
      </a>
      
      <button 
        @click="pollOrders()"
        class="flex-1 sm:flex-none bg-dark-800 hover:bg-dark-700 text-slate-300 px-4 py-2.5 rounded-xl text-xs border border-slate-700/60 font-semibold flex items-center justify-center gap-2 transition cursor-pointer"
      >
        <i class="fa-solid fa-arrows-rotate animate-spin" style="animation-duration: 4s;"></i> Muat Ulang
      </button>
    </div>
  </div>

  <!-- Messages -->
  <%- include('../partials/alerts') %>

  <!-- Filter tabs -->
  <div class="flex items-center space-x-2 bg-dark-800 p-1.5 rounded-2xl border border-slate-800 max-w-md">
    <button 
      @click="activeFilter = 'active'"
      :class="activeFilter === 'active' ? 'bg-brand-600 text-white shadow-lg shadow-brand-500/25' : 'text-slate-400 hover:text-slate-200'"
      class="flex-1 text-center py-2 text-xs font-semibold rounded-xl transition cursor-pointer"
    >Aktif (Antrean)</button>
    <button 
      @click="activeFilter = 'pending'"
      :class="activeFilter === 'pending' ? 'bg-brand-600 text-white shadow-lg shadow-brand-500/25' : 'text-slate-400 hover:text-slate-200'"
      class="flex-1 text-center py-2 text-xs font-semibold rounded-xl transition cursor-pointer"
    >Pending</button>
    <button 
      @click="activeFilter = 'processing'"
      :class="activeFilter === 'processing' ? 'bg-brand-600 text-white shadow-lg shadow-brand-500/25' : 'text-slate-400 hover:text-slate-200'"
      class="flex-1 text-center py-2 text-xs font-semibold rounded-xl transition cursor-pointer"
    >Diproses</button>
    <button 
      @click="activeFilter = 'completed'"
      :class="activeFilter === 'completed' ? 'bg-brand-600 text-white shadow-lg shadow-brand-500/25' : 'text-slate-400 hover:text-slate-200'"
      class="flex-1 text-center py-2 text-xs font-semibold rounded-xl transition cursor-pointer"
    >Selesai</button>
  </div>

  <!-- Orders Grid (Mobile-First / Card Layout for Waiters) -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <template x-for="order in filteredOrders" :key="order.id">
      <div 
        class="glass-card rounded-2xl border flex flex-col justify-between shadow-xl transition-all"
        :class="{
          'border-red-500/20 bg-red-950/5': order.status === 'pending',
          'border-amber-500/20 bg-amber-950/5': order.status === 'processing',
          'border-indigo-500/20 bg-indigo-950/5': order.status === 'completed'
        }"
      >
        <!-- Card Header -->
        <div class="p-5 border-b border-slate-800/80 flex items-center justify-between">
          <div>
            <span class="text-white font-extrabold text-lg">#<span x-text="order.id"></span></span>
            <span class="text-slate-400 text-xs block" x-text="new Date(order.createdAt).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'})"></span>
          </div>
          <span 
            class="text-[10px] font-extrabold uppercase px-2 py-0.5 rounded-full"
            :class="order.type === 'dine-in' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' : 'bg-purple-500/10 text-purple-400 border border-purple-500/20'"
            x-text="order.type === 'dine-in' ? 'Dine-In' : 'Delivery'"
          ></span>
        </div>

        <!-- Card Body -->
        <div class="p-5 flex-grow space-y-4">
          <!-- Customer Detail -->
          <div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-wider">Nama Pelanggan</p>
            <p class="text-white font-semibold text-base mt-0.5" x-text="order.customerName"></p>
          </div>

          <!-- Meja / Alamat -->
          <div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-wider" x-text="order.type === 'dine-in' ? 'Nomor Meja' : 'Alamat Pengiriman'"></p>
            <p class="text-slate-200 text-sm font-medium mt-0.5" x-text="order.type === 'dine-in' ? order.tableNumber : order.address"></p>
          </div>

          <!-- Item list -->
          <div class="bg-dark-900/50 p-3.5 rounded-xl border border-slate-800">
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-wider mb-2">Daftar Hidangan</p>
            <ul class="space-y-2 text-slate-300 text-sm">
              <template x-for="item in order.items" :key="item.id">
                <li class="flex items-start justify-between gap-4">
                  <span>
                    <strong class="text-brand-500 font-bold" x-text="item.quantity + (item.menu.priceType === 'kg' ? ' Kg' : ' Pcs')"></strong> 
                    <span x-text="item.menu.name"></span>
                    <span x-show="item.notes" class="block text-[10px] text-slate-500 italic mt-0.5" x-text="'Catatan: ' + item.notes"></span>
                  </span>
                </li>
              </template>
            </ul>
          </div>
        </div>

        <!-- Card Footer (Actions) -->
        <div class="p-5 border-t border-slate-800/80 bg-dark-950/20 flex items-center justify-between gap-4">
          <!-- Status Badge -->
          <div class="flex items-center gap-1.5">
            <span 
              class="w-2 h-2 rounded-full"
              :class="{
                'bg-red-500 animate-ping': order.status === 'pending',
                'bg-amber-500 animate-pulse': order.status === 'processing',
                'bg-indigo-500': order.status === 'completed'
              }"
            ></span>
            <span 
              class="text-[10px] font-bold uppercase text-slate-400"
              x-text="
                order.status === 'pending' ? 'Menunggu Dapur' :
                order.status === 'processing' ? 'Sedang Dimasak' : 'Selesai & Sajikan'
              "
            ></span>
          </div>

          <!-- Action Buttons (Flex container) -->
          <div class="flex items-center gap-2">
            <!-- Dynamic QRIS Button -->
            <% if (settings.qris_active === 'true') { %>
              <button 
                type="button" 
                @click="openQrisModal(order.id)" 
                class="bg-blue-600/90 hover:bg-blue-500 text-white text-xs font-bold px-3 py-2 rounded-xl transition cursor-pointer flex items-center justify-center gap-1 shadow-lg shadow-blue-600/10"
              >
                <i class="fa-solid fa-qrcode text-xs"></i> QRIS
              </button>
            <% } %>

            <!-- Action Button Form -->
            <form :action="'/orders/' + order.id + '/status'" method="POST" class="inline">
              <template x-if="order.status === 'pending'">
                <button 
                  type="submit" 
                  name="status" 
                  value="processing" 
                  class="bg-amber-600 hover:bg-amber-500 text-white text-xs font-bold px-4 py-2 rounded-xl transition cursor-pointer flex items-center gap-1.5 shadow-lg shadow-amber-600/10"
                >
                  <i class="fa-solid fa-fire-burner"></i> Masak
                </button>
              </template>
              <template x-if="order.status === 'processing'">
                <button 
                  type="submit" 
                  name="status" 
                  value="completed" 
                  class="bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold px-4 py-2 rounded-xl transition cursor-pointer flex items-center gap-1.5 shadow-lg shadow-indigo-600/10"
                >
                  <i class="fa-solid fa-check"></i> Selesai
                </button>
              </template>
            </form>
          </div>
        </div>
      </div>
    </template>

    <!-- Empty State -->
    <div 
      x-show="filteredOrders.length === 0" 
      class="col-span-full py-16 flex flex-col items-center justify-center text-center text-slate-500"
    >
      <i class="fa-solid fa-utensils text-4xl mb-3 text-slate-600"></i>
      <p class="font-semibold text-sm">Tidak ada antrean pesanan aktif</p>
      <p class="text-xs mt-1 text-slate-500">Semua pesanan selesai dihidangkan atau antrean kosong.</p>
    </div>
  </div>

  <!-- QRIS Payment Modal -->
  <div 
    x-show="qrisModalOpen" 
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-dark-950/80 backdrop-blur-sm"
    x-transition
    style="display: none;"
  >
    <div 
      @click.away="qrisModalOpen = false"
      class="bg-dark-900 border border-slate-800 rounded-3xl w-full max-w-md overflow-hidden shadow-2xl relative flex flex-col max-h-[90vh]"
    >
      <!-- Modal Header -->
      <div class="p-6 border-b border-slate-800 flex justify-between items-center bg-dark-850">
        <div>
          <h3 class="text-white font-extrabold text-lg flex items-center gap-2">
            <i class="fa-solid fa-qrcode text-brand-500"></i> QRIS Pembayaran Dinamis
          </h3>
          <p class="text-[10px] text-slate-400 mt-0.5">Tunjukkan QR code ini ke pelanggan untuk scan langsung</p>
        </div>
        <button 
          @click="qrisModalOpen = false" 
          class="text-slate-400 hover:text-white bg-dark-800 hover:bg-dark-750 p-2 rounded-xl transition cursor-pointer"
        >
          <i class="fa-solid fa-xmark text-sm"></i>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6 flex flex-col items-center justify-center space-y-6 overflow-y-auto flex-grow">
        <!-- Loading State -->
        <div x-show="qrisLoading" class="py-12 flex flex-col items-center justify-center space-y-3">
          <i class="fa-solid fa-spinner animate-spin text-brand-500 text-3xl"></i>
          <p class="text-xs text-slate-400 font-semibold">Menghasilkan kode QRIS...</p>
        </div>

        <!-- Error State -->
        <div x-show="qrisError" class="w-full text-center py-6 space-y-3">
          <div class="w-12 h-12 bg-red-500/10 text-red-400 rounded-full flex items-center justify-center mx-auto text-xl">
            <i class="fa-solid fa-circle-exclamation"></i>
          </div>
          <p class="text-sm text-slate-300 font-medium" x-text="qrisError"></p>
          <button 
            @click="qrisModalOpen = false" 
            class="bg-dark-800 hover:bg-dark-700 text-slate-300 px-4 py-2 rounded-xl text-xs font-semibold border border-slate-700/50 cursor-pointer"
          >
            Tutup
          </button>
        </div>

        <!-- QRIS Content -->
        <div x-show="!qrisLoading && !qrisError && qrisOrder" class="w-full flex flex-col items-center space-y-4" x-data="{ cashReceived: 0 }">
          <!-- Order Metadata -->
          <div class="text-center w-full bg-dark-950/40 p-4 rounded-2xl border border-slate-850">
            <span class="text-[10px] font-extrabold uppercase px-2 py-0.5 rounded-full bg-brand-500/10 text-brand-400 border border-brand-500/20" x-text="qrisOrder ? (qrisOrder.type === 'dine-in' ? 'Dine-In' : 'Delivery') : ''"></span>
            <h4 class="text-white font-extrabold text-base mt-2" x-text="qrisOrder ? '#' + qrisOrder.id + ' - ' + qrisOrder.customerName : ''"></h4>
            <p class="text-xs text-slate-400 mt-1" x-text="qrisOrder ? (qrisOrder.type === 'dine-in' ? 'Nomor Meja: ' + qrisOrder.tableNumber : 'Pengiriman Delivery') : ''"></p>
          </div>

          <!-- QR Code Box -->
          <div class="bg-white p-3.5 rounded-2xl border border-slate-200 shadow-inner flex items-center justify-center">
            <img 
              :src="qrisQrUrl" 
              alt="QRIS QR Code" 
              class="w-48 h-48 object-contain"
            />
          </div>

          <!-- Price & Locked Amount -->
          <div class="text-center">
            <span class="text-xs font-black text-brand-500 bg-brand-500/10 border border-brand-500/20 px-4 py-1.5 rounded-full uppercase tracking-wider block w-fit mx-auto">
              Total: Rp <span x-text="qrisOrder ? parseFloat(qrisOrder.totalPrice).toLocaleString('id-ID') : ''"></span>
            </span>
            <p class="text-[9px] text-slate-500 mt-2">Nominal terenkripsi secara dinamis. Pelanggan cukup scan tanpa menginput angka pembayaran.</p>
          </div>

          <!-- Pembayaran Tunai (Cash) Section -->
          <div class="w-full border-t border-slate-800/80 pt-4 mt-2">
            <label class="block text-left text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5"><i class="fa-solid fa-money-bill-wave text-brand-500 mr-1.5"></i>Pembayaran Tunai (Cash)</label>
            <div class="space-y-3">
              <div class="flex gap-2">
                <span style="background-color: #0b1120 !important;" class="border border-slate-800/60 text-slate-400 text-xs px-3 py-2.5 rounded-xl flex items-center justify-center font-bold">Rp</span>
                <input 
                  type="number" 
                  x-model.number="cashReceived"
                  placeholder="Masukkan uang diterima..." 
                  style="background-color: #0b1120 !important; color: #ffffff !important;"
                  class="w-full border border-slate-800/60 rounded-xl px-3 py-2.5 text-xs text-white placeholder-slate-600 focus:outline-none focus:border-brand-500 font-bold"
                />
              </div>
              <!-- Change Calculation -->
              <template x-if="cashReceived > 0">
                <div class="flex justify-between items-center bg-dark-950/60 p-3 rounded-xl border border-slate-850 text-xs">
                  <span class="text-slate-400 font-semibold">Uang Kembalian:</span>
                  <span 
                    class="font-black text-sm"
                    :class="cashReceived >= qrisOrder.totalPrice ? 'text-emerald-400' : 'text-red-400'"
                    x-text="cashReceived >= qrisOrder.totalPrice 
                      ? 'Rp ' + parseFloat(cashReceived - qrisOrder.totalPrice).toLocaleString('id-ID')
                      : 'Kurang: Rp ' + parseFloat(qrisOrder.totalPrice - cashReceived).toLocaleString('id-ID')"
                  ></span>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>

      <!-- Modal Footer -->
      <div x-show="!qrisLoading && !qrisError && qrisOrder" class="p-6 border-t border-slate-800 bg-dark-850 flex flex-col gap-3 w-full">
        <div class="flex gap-2 w-full">
          <button 
            @click="qrisModalOpen = false" 
            class="flex-1 bg-dark-800 hover:bg-dark-750 text-slate-300 py-3 rounded-xl text-xs font-bold transition border border-slate-700/50 cursor-pointer"
          >
            Tutup
          </button>
          
          <a 
            :href="'/orders/' + (qrisOrder ? qrisOrder.id : '') + '/print'"
            target="_blank"
            class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-3 rounded-xl text-xs font-bold transition flex items-center justify-center gap-1.5 shadow-lg shadow-blue-600/15 cursor-pointer"
          >
            <i class="fa-solid fa-print"></i> Struk
          </a>
        </div>
        
        <form :action="'/orders/' + (qrisOrder ? qrisOrder.id : '') + '/status'" method="POST" class="w-full">
          <input type="hidden" name="status" value="paid">
          <button 
            type="submit" 
            class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3 rounded-xl text-xs font-bold transition flex items-center justify-center gap-1.5 shadow-lg shadow-emerald-600/15 cursor-pointer"
          >
            <i class="fa-solid fa-cash-register"></i> Tandai Lunas
          </button>
        </form>
      </div>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>
