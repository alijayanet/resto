<%- include('partials/header') %>

<div class="flex-grow flex items-center justify-center py-12 px-4 bg-gradient-to-b from-dark-900 via-dark-800 to-dark-900">
  <div class="max-w-md w-full relative">
    
    <!-- Decorative background glow -->
    <div class="absolute inset-0 bg-brand-500 rounded-3xl blur-3xl opacity-10"></div>
    
    <div class="relative glass-card border border-slate-700/50 rounded-3xl p-6 sm:p-8 shadow-2xl space-y-6">
      
      <!-- Brand Header -->
      <div class="text-center space-y-2">
        <a href="/" class="inline-flex items-center space-x-2 bg-gradient-to-tr from-brand-500 to-accent-500 p-2.5 rounded-2xl shadow-xl shadow-brand-500/10 hover:scale-105 transition-transform duration-300">
          <i class="fa-solid fa-shrimp text-white text-3xl"></i>
        </a>
        <h3 class="text-white text-2xl font-black tracking-tight">Staff Portal Login</h3>
        <p class="text-slate-400 text-xs">Akses khusus Admin, Pelayan, dan Kasir <%= settings.resto_name || 'Dermaga Seafood' %></p>
      </div>

      <!-- Messages -->
      <%- include('partials/alerts') %>

      <!-- Form -->
      <form action="/login" method="POST" class="space-y-4">
        <!-- Username -->
        <div>
          <label for="username" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Username</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-solid fa-user text-sm"></i>
            </span>
            <input 
              type="text" 
              name="username" 
              id="username" 
              required 
              placeholder="Masukkan username..."
              class="w-full bg-dark-900 border border-slate-700/80 rounded-xl pl-10 pr-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition duration-300"
            />
          </div>
        </div>

        <!-- Password -->
        <div>
          <label for="password" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-solid fa-lock text-sm"></i>
            </span>
            <input 
              type="password" 
              name="password" 
              id="password" 
              required 
              placeholder="Masukkan password..."
              class="w-full bg-dark-900 border border-slate-700/80 rounded-xl pl-10 pr-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition duration-300"
            />
          </div>
        </div>

        <!-- Login Button -->
        <button 
          type="submit"
          class="w-full bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white py-3 rounded-xl text-sm font-bold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30 transition duration-300 cursor-pointer"
        >
          Masuk ke Portal
        </button>
      </form>

      <!-- Back to Landing Link -->
      <div class="text-center pt-2">
        <a href="/" class="text-xs text-brand-500 hover:underline">
          <i class="fa-solid fa-arrow-left-long mr-1"></i> Kembali ke Halaman Utama
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>
