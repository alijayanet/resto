<% if (typeof successMessage !== 'undefined' && successMessage) { %>
  <div 
    x-data="{ show: true }" 
    x-show="show" 
    x-init="setTimeout(() => show = false, 5000)"
    x-transition:leave="transition ease-in duration-300"
    x-transition:leave-start="opacity-100 scale-100"
    x-transition:leave-end="opacity-0 scale-95"
    class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-3.5 rounded-xl text-xs flex items-center justify-between gap-2.5 shadow-lg shadow-emerald-550/5 fade-in"
  >
    <div class="flex items-center gap-2.5">
      <i class="fa-solid fa-circle-check text-sm"></i>
      <span><%= successMessage %></span>
    </div>
    <button @click="show = false" class="text-emerald-400 hover:text-white transition duration-200 p-1 rounded-lg hover:bg-emerald-500/10 cursor-pointer">
      <i class="fa-solid fa-xmark text-xs"></i>
    </button>
  </div>
<% } %>

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div 
    x-data="{ show: true }" 
    x-show="show" 
    x-init="setTimeout(() => show = false, 5000)"
    x-transition:leave="transition ease-in duration-300"
    x-transition:leave-start="opacity-100 scale-100"
    x-transition:leave-end="opacity-0 scale-95"
    class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3.5 rounded-xl text-xs flex items-center justify-between gap-2.5 shadow-lg shadow-red-550/5 fade-in"
  >
    <div class="flex items-center gap-2.5">
      <i class="fa-solid fa-circle-exclamation text-sm"></i>
      <span><%= errorMessage %></span>
    </div>
    <button @click="show = false" class="text-red-400 hover:text-white transition duration-200 p-1 rounded-lg hover:bg-red-500/10 cursor-pointer">
      <i class="fa-solid fa-xmark text-xs"></i>
    </button>
  </div>
<% } %>
