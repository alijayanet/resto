<footer id="about-resto" class="bg-dark-800 border-t border-slate-800/80 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Resto Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <div class="bg-gradient-to-tr from-brand-500 to-accent-500 p-2 rounded-xl">
            <i class="fa-solid fa-shrimp text-white text-xl"></i>
          </div>
          <span class="font-extrabold text-xl text-white tracking-wide">
            <%= settings.resto_name || 'Dermaga Seafood' %>
          </span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          <%= settings.about_text || 'Menyajikan kelezatan hidangan laut segar tangkapan nelayan lokal setiap hari dengan bumbu rempah pilihan khas nusantara.' %>
        </p>
      </div>

      <!-- Opening Hours -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Jam Operasional</h4>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li class="flex justify-between border-b border-slate-700/30 pb-2">
            <span>Senin - Jumat</span>
            <span class="text-slate-200"><%= settings.hours_weekday || '11.00 - 22.00 WIB' %></span>
          </li>
          <li class="flex justify-between border-b border-slate-700/30 pb-2">
            <span>Sabtu - Minggu</span>
            <span class="text-slate-200"><%= settings.hours_weekend || '10.00 - 23.00 WIB' %></span>
          </li>
        </ul>
      </div>

      <!-- Resto Location & Contact -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Kontak & Alamat</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li class="flex items-start gap-2.5">
            <i class="fa-solid fa-location-dot text-brand-500 mt-1"></i>
            <span><%= settings.resto_address || 'Kawasan Pantai Indah, Jakarta' %></span>
          </li>
          <li class="flex items-center gap-2.5">
            <i class="fa-solid fa-phone text-brand-500"></i>
            <span>+<%= settings.resto_whatsapp || '6281234567890' %> (WhatsApp)</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom Copyright -->
    <div class="border-t border-slate-800 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between text-xs text-slate-500 gap-4">
      <p>&copy; <%= new Date().getFullYear() %> <%= settings.resto_name || 'Dermaga Seafood' %>. Semua Hak Cipta Dilindungi.</p>
      <div class="flex space-x-4">
        <a href="/login" class="hover:text-slate-300">Staff Access</a>
        <span>&bull;</span>
        <a href="#" class="hover:text-slate-300">Syarat & Ketentuan</a>
      </div>
    </div>
  </div>
</footer>
</body>
</html>
