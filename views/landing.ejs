<%- include('partials/header') %>
<%- include('partials/navbar') %>

  <!-- Waiter/Staff Order Mode Banner -->
  <% if (typeof user !== 'undefined' && user) { %>
    <div class="bg-brand-600/90 bg-sky-650/95 border-b border-sky-500/30 py-3.5 px-4 text-center sticky top-[68px] z-40 backdrop-blur-md">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-sky-50">
        <div class="flex items-center gap-2">
          <i class="fa-solid fa-circle-user text-base text-yellow-400"></i>
          <span>Mode Input Order Pelayan Aktif: <strong><%= user.name %> (<%= user.role === 'admin' ? 'Admin' : 'Pelayan' %>)</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <% const dashUrl = user.role === 'admin' ? '/admin/dashboard' : '/waiter/orders' %>
          <a href="<%= dashUrl %>" class="bg-white/10 hover:bg-white/20 px-3.5 py-1.5 rounded-lg text-xs font-bold transition flex items-center gap-1.5 border border-white/15">
            <i class="fa-solid fa-gauge"></i> Kembali ke Dashboard
          </a>
        </div>
      </div>
    </div>
  <% } %>

<!-- Initialize Alpine.js Cart Store -->
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.store('cart', {
      items: JSON.parse(localStorage.getItem('resto_cart') || '[]'),
      isOpen: false,
      
      get count() {
        return this.items.reduce((sum, item) => sum + (item.priceType === 'kg' ? 1 : item.quantity), 0);
      },
      
      get total() {
        return this.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      },
      
      save() {
        localStorage.setItem('resto_cart', JSON.stringify(this.items));
      },
      
      addItem(menu) {
        const existing = this.items.find(item => item.menuId === menu.id);
        if (existing) {
          existing.quantity += (menu.priceType === 'kg' ? 0.5 : 1);
        } else {
          this.items.push({
            menuId: menu.id,
            name: menu.name,
            price: parseFloat(menu.price),
            priceType: menu.priceType,
            image: menu.image,
            quantity: (menu.priceType === 'kg' ? 1.0 : 1),
            notes: ''
          });
        }
        this.save();
      },
      
      removeItem(menuId) {
        this.items = this.items.filter(item => item.menuId !== menuId);
        this.save();
      },
      
      updateQty(menuId, qty) {
        const item = this.items.find(item => item.menuId === menuId);
        if (item) {
          const parsed = parseFloat(qty);
          if (isNaN(parsed) || parsed <= 0) {
            this.removeItem(menuId);
          } else {
            item.quantity = item.priceType === 'pcs' ? Math.round(parsed) : parsed;
            this.save();
          }
        }
      },
      
      clear() {
        this.items = [];
        this.save();
      }
    });
  });
</script>

<div 
  x-data="{ 
    selectedCategory: 'semua',
    searchQuery: '',
    checkoutType: 'dine-in',
    checkoutModalOpen: false,
    checkoutName: '',
    checkoutTable: '',
    checkoutAddress: '',
    
    menus: <%= JSON.stringify(menus) %>,
    
    get filteredMenus() {
      return this.menus.filter(menu => {
        const matchCategory = this.selectedCategory === 'semua' || menu.category.toLowerCase() === this.selectedCategory.toLowerCase();
        const matchSearch = menu.name.toLowerCase().includes(this.searchQuery.toLowerCase()) || 
                            menu.description.toLowerCase().includes(this.searchQuery.toLowerCase());
        return matchCategory && matchSearch;
      });
    }
  }"
  @open-cart.window="$store.cart.isOpen = true"
  class="relative flex-grow"
  <!-- Messages -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <%- include('partials/alerts') %>
  </div>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-dark-800 to-dark-900 overflow-hidden py-16 sm:py-24 border-b border-slate-800/40">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 z-0 opacity-15">
      <div class="absolute top-12 left-12 w-64 h-64 bg-brand-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-12 right-12 w-96 h-96 bg-accent-500 rounded-full blur-3xl"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Hero Details -->
        <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
          <div class="inline-flex items-center space-x-2 bg-brand-500/10 border border-brand-500/20 px-3.5 py-1.5 rounded-full text-brand-500 text-xs sm:text-sm font-bold uppercase tracking-wider">
            <i class="fa-solid fa-star animate-pulse"></i>
            <span>Sensasi Seafood Bintang Lima</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight">
            <%= settings.hero_title || 'Kelezatan Seafood Segar Terbaik' %>
          </h1>
          <p class="text-slate-300 text-base sm:text-lg max-w-xl mx-auto lg:mx-0 leading-relaxed">
            <%= settings.hero_subtitle || 'Tangkap langsung dari laut dan dimasak dengan resep rahasia legendaris.' %>
          </p>
          <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4">
            <a 
              href="#menu-catalog" 
              class="bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white px-8 py-3.5 rounded-xl text-base font-bold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30 transition duration-300 flex items-center justify-center gap-2"
            >
              <i class="fa-solid fa-utensils"></i> Lihat Katalog Menu
            </a>
            <% if (settings.allow_ordering === 'true') { %>
              <button 
                @click="$dispatch('open-cart')"
                class="bg-dark-800 border border-slate-700/60 hover:bg-dark-700 text-slate-200 px-8 py-3.5 rounded-xl text-base font-bold transition duration-300 flex items-center justify-center gap-2"
              >
                <i class="fa-solid fa-cart-shopping text-brand-500"></i> Pesan Online Sekarang
              </button>
            <% } %>
          </div>
        </div>
        
        <!-- Hero Art / Logo Presentation -->
        <div class="lg:col-span-5 flex justify-center">
          <div class="relative">
            <!-- Glowing Ring -->
            <div class="absolute inset-0 bg-gradient-to-tr from-brand-500 to-accent-500 rounded-full blur-2xl opacity-20 animate-pulse"></div>
            <!-- Main Hero Boxed Logo -->
            <div class="relative glass-card p-8 rounded-3xl border border-slate-700/40 shadow-2xl flex flex-col items-center text-center max-w-sm">
              <div class="w-24 h-24 rounded-2xl overflow-hidden flex items-center justify-center bg-slate-800/60 p-2 shadow-xl shadow-brand-500/10 mb-6 border border-slate-700/40">
                <% if (settings.resto_logo && settings.resto_logo !== '/images/default-logo.png') { %>
                  <img src="<%= settings.resto_logo %>" alt="Logo Resto" class="w-full h-full object-contain" />
                <% } else { %>
                  <div class="bg-gradient-to-tr from-brand-600 to-accent-500 w-full h-full rounded-xl flex items-center justify-center">
                    <i class="fa-solid fa-fish text-white text-4xl"></i>
                  </div>
                <% } %>
              </div>
              <h3 class="text-white text-2xl font-black mb-2"><%= settings.resto_name || 'Dermaga Seafood' %></h3>
              <p class="text-slate-400 text-sm mb-4">Cita rasa laut sesungguhnya, diproses secara higienis dan disajikan hangat.</p>
              <div class="flex items-center gap-1.5 text-accent-500 font-semibold text-sm">
                <i class="fa-solid fa-location-dot"></i>
                <span class="text-xs text-slate-300 truncate max-w-[200px]"><%= settings.resto_address || 'Pantai Indah Kapuk' %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Notification Banner (Catalog Mode vs Ordering) -->
  <% if (settings.allow_ordering !== 'true') { %>
    <div class="bg-indigo-900/40 border-b border-indigo-700/30 py-4 px-4 text-center">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 text-sm text-indigo-200">
        <i class="fa-solid fa-circle-info text-brand-500 text-base"></i>
        <span><strong>Mode Katalog Digital Aktif:</strong> Pemesanan langsung dari website dimatikan sementara. Silakan beri tahu pelayan di meja Anda untuk memesan.</span>
      </div>
    </div>
  <% } %>

  <!-- Catalog Section -->
  <section id="menu-catalog" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Header Search and Title -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-10">
      <div>
        <h2 class="text-3xl font-extrabold text-white tracking-tight"><%= settings.menu_title || 'Koleksi Menu Hidangan' %></h2>
        <p class="text-slate-400 mt-2 text-sm sm:text-base"><%= settings.menu_subtitle || 'Silakan pilih kategori menu favorit Anda.' %></p>
      </div>
      
      <!-- Search Input -->
      <div class="relative w-full md:w-80">
        <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
          <i class="fa-solid fa-magnifying-glass text-sm"></i>
        </span>
        <input 
          type="text" 
          placeholder="<%= settings.search_placeholder || 'Cari hidangan...' %>" 
          x-model="searchQuery"
          class="w-full bg-dark-800 border border-slate-700/60 rounded-xl pl-10 pr-4 py-2.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition duration-300"
        />
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex items-center space-x-2 overflow-x-auto pb-4 mb-8 -mx-4 px-4 scrollbar-none">
      <% 
        const rawCats = settings.resto_categories || 'Ikan:ikan, Kepiting:kepiting, Udang:udang, Cumi-Cumi:cumi, Kerang:kerang, Minuman:minuman, Lainnya:lainnya';
        const parsedCats = rawCats.split(',').map(c => {
          const parts = c.trim().split(':');
          const label = parts[0].trim();
          const val = parts[1] ? parts[1].trim() : label.toLowerCase().replace(/\s+/g, '-');
          return { key: val, label };
        });
        
        const categories = [
          { key: 'semua', label: 'Semua Menu' },
          ...parsedCats
        ];
      %>
      
      <% categories.forEach(cat => { %>
        <button 
          @click="selectedCategory = '<%= cat.key %>'"
          :class="selectedCategory === '<%= cat.key %>' ? 'active-tab' : 'bg-dark-800 hover:bg-dark-700 text-slate-300 border border-slate-700/40'"
          class="px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center space-x-2 whitespace-nowrap transition duration-300 cursor-pointer"
        >
          <span><%= cat.label %></span>
        </button>
      <% }) %>
    </div>

    <!-- Menu Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      
      <!-- Loop via Alpine.js filteredMenus -->
      <template x-for="menu in filteredMenus" :key="menu.id">
        <div class="glass-card rounded-2xl overflow-hidden shadow-xl border border-slate-800 flex flex-col group hover:scale-[1.01] transition-transform duration-300">
          
          <!-- Menu Image -->
          <div class="relative aspect-video w-full overflow-hidden bg-dark-800">
            <img 
              :src="menu.image" 
              :alt="menu.name" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              onerror="this.src='/images/default-logo.png'"
            />
            <!-- Tag Category -->
            <span 
              x-text="menu.category"
              class="absolute top-3 left-3 bg-dark-900/80 backdrop-blur-md text-brand-500 text-[10px] font-extrabold uppercase px-2.5 py-1 rounded-full border border-brand-500/20 tracking-wider"
            ></span>
            <!-- Tag Price Type -->
            <span 
              class="absolute top-3 right-3 bg-accent-500 text-dark-900 text-[10px] font-extrabold uppercase px-2.5 py-1 rounded-full tracking-wider"
              x-text="'Per ' + menu.priceType"
            ></span>
          </div>

          <!-- Card Content -->
          <div class="p-5 flex flex-col flex-grow space-y-3">
            <div class="space-y-1">
              <h4 class="text-white text-lg font-bold truncate group-hover:text-brand-500 transition-colors" x-text="menu.name"></h4>
              <p class="text-slate-400 text-xs line-clamp-2 min-h-[32px] leading-relaxed" x-text="menu.description"></p>
            </div>
            
            <div class="flex items-baseline justify-between pt-2 mt-auto">
              <div class="text-slate-400 text-[10px] uppercase font-bold tracking-wider">Harga</div>
              <div class="text-white text-xl font-extrabold">
                <span class="text-xs font-normal text-slate-400">Rp</span>
                <span x-text="parseFloat(menu.price).toLocaleString('id-ID')"></span>
                <span class="text-xs font-normal text-slate-400">/<span x-text="menu.priceType"></span></span>
              </div>
            </div>

            <!-- Action Button -->
            <% if (settings.allow_ordering === 'true' || (typeof user !== 'undefined' && user)) { %>
              <button 
                @click="$store.cart.addItem(menu)"
                class="w-full bg-brand-600/20 hover:bg-brand-600 border border-brand-500/30 hover:border-brand-500 text-brand-500 hover:text-white py-2.5 rounded-xl text-sm font-semibold transition duration-300 flex items-center justify-center gap-2 cursor-pointer mt-2"
              >
                <i class="fa-solid fa-plus-circle"></i> Tambah Keranjang
              </button>
            <% } %>
          </div>

        </div>
      </template>

      <!-- Empty State -->
      <div 
        x-show="filteredMenus.length === 0" 
        class="col-span-full py-12 flex flex-col items-center justify-center text-center text-slate-500"
      >
        <i class="fa-solid fa-utensils text-4xl mb-3 text-slate-600"></i>
        <p class="font-semibold text-lg text-slate-400">Menu tidak ditemukan</p>
        <p class="text-xs mt-1 text-slate-500">Coba ganti kategori filter atau kata kunci pencarian Anda.</p>
      </div>

    </div>
  </section>

  <!-- Cart Slide-out Drawer (Alpine.js controlled) -->
  <% if (settings.allow_ordering === 'true' || (typeof user !== 'undefined' && user)) { %>
    <div 
      x-show="$store.cart.isOpen"
      class="fixed inset-0 z-50 overflow-hidden"
      style="display: none;"
    >
      <!-- Background Overlay -->
      <div 
        @click="$store.cart.isOpen = false"
        x-show="$store.cart.isOpen"
        x-transition:enter="ease-in-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="ease-in-out duration-300"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="absolute inset-0 bg-dark-900/80 backdrop-blur-sm transition-opacity"
      ></div>

      <div class="fixed inset-y-0 right-0 pl-10 max-w-full flex">
        <div 
          x-show="$store.cart.isOpen"
          x-transition:enter="transform transition ease-in-out duration-300"
          x-transition:enter-start="translate-x-full"
          x-transition:enter-end="translate-x-0"
          x-transition:leave="transform transition ease-in-out duration-300"
          x-transition:leave-start="translate-x-0"
          x-transition:leave-end="translate-x-full"
          class="w-screen max-w-md"
        >
          <!-- Drawer Content Panel -->
          <div class="h-full flex flex-col bg-dark-800 border-l border-slate-700/60 shadow-2xl">
            
            <!-- Drawer Header -->
            <div class="px-6 py-5 border-b border-slate-700/40 flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <i class="fa-solid fa-cart-shopping text-brand-500"></i>
                <h3 class="text-lg font-bold text-white">Keranjang Pesanan</h3>
              </div>
              <button 
                @click="$store.cart.isOpen = false"
                class="text-slate-400 hover:text-white transition"
              >
                <i class="fa-solid fa-xmark text-lg"></i>
              </button>
            </div>

            <!-- Drawer Items (Scrollable) -->
            <div class="flex-grow overflow-y-auto px-6 py-4 space-y-4">
              <template x-for="item in $store.cart.items" :key="item.menuId">
                <div class="flex gap-4 bg-dark-900/40 p-3 rounded-xl border border-slate-800">
                  <!-- Thumbnail -->
                  <div class="w-16 h-16 rounded-lg overflow-hidden bg-dark-800 flex-shrink-0">
                    <img :src="item.image" :alt="item.name" class="w-full h-full object-cover" onerror="this.src='/images/default-logo.png'"/>
                  </div>
                  
                  <!-- Details -->
                  <div class="flex-grow flex flex-col justify-between">
                    <div>
                      <div class="flex justify-between items-start gap-2">
                        <h5 class="text-sm font-semibold text-white truncate max-w-[150px]" x-text="item.name"></h5>
                        <button 
                          @click="$store.cart.removeItem(item.menuId)"
                          class="text-slate-500 hover:text-red-400 transition"
                        >
                          <i class="fa-solid fa-trash-can text-xs"></i>
                        </button>
                      </div>
                      
                      <!-- Price -->
                      <p class="text-xs text-brand-500 font-bold mt-0.5">
                        Rp <span x-text="parseFloat(item.price).toLocaleString('id-ID')"></span>/<span x-text="item.priceType"></span>
                      </p>
                    </div>

                    <!-- Quantity Adjuster and Notes -->
                    <div class="flex items-center justify-between gap-4 mt-2">
                      <input 
                        type="text" 
                        placeholder="Catatan (misal: Pedas)" 
                        x-model="item.notes"
                        class="bg-dark-800 border border-slate-700/50 rounded-lg px-2.5 py-1 text-[10px] text-slate-300 placeholder-slate-600 focus:outline-none focus:border-brand-500 flex-grow"
                      />
                      
                      <!-- Quantity Adjuster -->
                      <div class="flex items-center space-x-1.5 bg-dark-800 border border-slate-700/50 rounded-lg p-0.5">
                        <button 
                          @click="$store.cart.updateQty(item.menuId, item.priceType === 'kg' ? -0.5 : -1)"
                          class="w-5 h-5 flex items-center justify-center text-xs text-slate-400 hover:text-white"
                        >
                          <i class="fa-solid fa-minus"></i>
                        </button>
                        
                        <!-- Form Input Quantity (Supports decimal for KG) -->
                        <input 
                          type="number" 
                          :step="item.priceType === 'kg' ? '0.1' : '1'"
                          :value="item.quantity"
                          @change="$store.cart.updateQty(item.menuId, $event.target.value)"
                          class="bg-transparent text-center text-xs text-white w-10 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                        />
                        
                        <button 
                          @click="$store.cart.updateQty(item.menuId, item.priceType === 'kg' ? 0.5 : 1)"
                          class="w-5 h-5 flex items-center justify-center text-xs text-slate-400 hover:text-white"
                        >
                          <i class="fa-solid fa-plus"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </template>

              <!-- Empty State in Cart -->
              <div 
                x-show="$store.cart.count === 0"
                class="h-64 flex flex-col items-center justify-center text-slate-500 text-center"
              >
                <i class="fa-solid fa-cart-shopping text-3xl mb-2 text-slate-600"></i>
                <p class="font-semibold text-sm">Keranjang kosong</p>
                <p class="text-xs mt-1 text-slate-500">Tambahkan sajian laut lezat ke keranjang Anda.</p>
              </div>

            </div>

            <!-- Drawer Footer (Subtotal and Checkout) -->
            <div 
              x-show="$store.cart.count > 0"
              class="px-6 py-5 border-t border-slate-700/40 bg-dark-900/30 space-y-4"
            >
              <div class="flex justify-between items-center text-slate-300">
                <span class="text-sm">Subtotal</span>
                <span class="text-white text-lg font-bold">
                  Rp <span x-text="$store.cart.total.toLocaleString('id-ID')"></span>
                </span>
              </div>
              
              <button 
                @click="checkoutModalOpen = true; $store.cart.isOpen = false"
                class="w-full bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white py-3 rounded-xl text-sm font-semibold shadow-lg shadow-brand-500/20 transition cursor-pointer text-center block"
              >
                Lanjutkan Pemesanan
              </button>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Checkout Modal Form -->
    <div 
      x-show="checkoutModalOpen"
      class="fixed inset-0 z-50 overflow-y-auto flex items-center justify-center p-4"
      style="display: none;"
    >
      <!-- Background Overlay -->
      <div 
        @click="checkoutModalOpen = false"
        class="fixed inset-0 bg-dark-900/80 backdrop-blur-sm transition-opacity"
      ></div>

      <!-- Modal Card -->
      <div 
        x-show="checkoutModalOpen"
        x-transition:enter="ease-out duration-300"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="ease-in duration-200"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-95"
        class="relative bg-dark-800 border border-slate-700/80 rounded-2xl max-w-md w-full shadow-2xl p-6"
      >
        <div class="flex items-center justify-between pb-4 border-b border-slate-700/40 mb-5">
          <h3 class="text-lg font-bold text-white"><i class="fa-solid fa-circle-check text-brand-500 mr-2"></i> Konfirmasi Pesanan</h3>
          <button @click="checkoutModalOpen = false" class="text-slate-400 hover:text-white transition">
            <i class="fa-solid fa-xmark text-lg"></i>
          </button>
        </div>

        <!-- Checkout Form Submission (Express backend handler) -->
        <form action="/order" method="POST" class="space-y-4">
          <!-- Items Payload inside Hidden Inputs -->
          <template x-for="(item, index) in $store.cart.items" :key="item.menuId">
            <div>
              <input type="hidden" :name="'items['+index+'][menuId]'" :value="item.menuId" />
              <input type="hidden" :name="'items['+index+'][name]'" :value="item.name" />
              <input type="hidden" :name="'items['+index+'][quantity]'" :value="item.quantity" />
              <input type="hidden" :name="'items['+index+'][notes]'" :value="item.notes" />
            </div>
          </template>

          <!-- Customer Name -->
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Nama Lengkap</label>
            <input 
              type="text" 
              name="customerName"
              required 
              placeholder="Contoh: Budi Santoso"
              class="w-full bg-dark-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition"
            />
          </div>

          <!-- Checkout Type (Dine-in or Delivery) -->
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Tipe Layanan</label>
            <div class="grid grid-cols-2 gap-3">
              <label 
                class="flex items-center justify-center gap-2 border px-4 py-2.5 rounded-xl text-sm font-semibold transition cursor-pointer select-none"
                :class="checkoutType === 'dine-in' ? 'border-brand-500 bg-brand-500/10 text-white' : 'border-slate-700 bg-dark-900 text-slate-400 hover:bg-dark-800'"
              >
                <input 
                  type="radio" 
                  name="type" 
                  value="dine-in" 
                  x-model="checkoutType"
                  class="hidden"
                />
                <i class="fa-solid fa-chair-office text-xs"></i> Makan di Sini
              </label>

              <label 
                class="flex items-center justify-center gap-2 border px-4 py-2.5 rounded-xl text-sm font-semibold transition cursor-pointer select-none"
                :class="checkoutType === 'delivery' ? 'border-brand-500 bg-brand-500/10 text-white' : 'border-slate-700 bg-dark-900 text-slate-400 hover:bg-dark-800'"
              >
                <input 
                  type="radio" 
                  name="type" 
                  value="delivery" 
                  x-model="checkoutType"
                  class="hidden"
                />
                <i class="fa-solid fa-truck text-xs"></i> Kirim (Delivery)
              </label>
            </div>
          </div>

          <!-- Dine-In Specific (Table Number Dropdown) -->
          <div x-show="checkoutType === 'dine-in'">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Nomor Meja *</label>
            <select 
              name="tableNumber"
              ::required="checkoutType === 'dine-in'"
              class="w-full bg-dark-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition"
            >
              <option value="" disabled selected>-- Pilih Nomor Meja --</option>
              <% for (let i = 1; i <= 20; i++) { %>
                <% const tableVal = `Meja ${String(i).padStart(2, '0')}` %>
                <option value="<%= tableVal %>"><%= tableVal %></option>
              <% } %>
            </select>
          </div>

          <!-- Delivery Specific (Address) -->
          <div x-show="checkoutType === 'delivery'" style="display: none;">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Alamat Pengiriman</label>
            <textarea 
              name="address"
              ::required="checkoutType === 'delivery'"
              placeholder="Masukkan alamat pengiriman lengkap..."
              rows="3"
              class="w-full bg-dark-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition"
            ></textarea>
          </div>

          <!-- Waiter Payment Action Selector (Only visible to logged-in staff) -->
          <% if (typeof user !== 'undefined' && user) { %>
            <div class="border-t border-slate-800 pt-4 mt-4 space-y-3">
              <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5"><i class="fa-solid fa-cash-register text-brand-500 mr-1.5"></i>Status Awal Pembayaran</label>
              <div class="grid grid-cols-2 gap-3" x-data="{ initStatus: 'pending' }">
                <label 
                  class="flex items-center justify-center gap-2 border px-4 py-2.5 rounded-xl text-xs font-bold transition cursor-pointer select-none"
                  :class="initStatus === 'pending' ? 'border-brand-500 bg-brand-500/10 text-white' : 'border-slate-700 bg-dark-900 text-slate-400 hover:bg-dark-800'"
                >
                  <input 
                    type="radio" 
                    name="status" 
                    value="pending" 
                    x-model="initStatus"
                    class="hidden"
                  />
                  Antrean (Belum Bayar)
                </label>

                <label 
                  class="flex items-center justify-center gap-2 border px-4 py-2.5 rounded-xl text-xs font-bold transition cursor-pointer select-none"
                  :class="initStatus === 'paid' ? 'border-emerald-500 bg-emerald-500/10 text-white' : 'border-slate-700 bg-dark-900 text-slate-400 hover:bg-dark-800'"
                >
                  <input 
                    type="radio" 
                    name="status" 
                    value="paid" 
                    x-model="initStatus"
                    class="hidden"
                  />
                  Langsung Lunas (Paid)
                </label>
              </div>
            </div>
          <% } %>

          <div class="border-t border-slate-700/40 pt-4 mt-6">
            <button 
              type="submit" 
              class="w-full bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white py-3 rounded-xl text-sm font-bold shadow-lg shadow-brand-500/20 transition cursor-pointer"
            >
              Kirim Pesanan (Total: Rp <span x-text="$store.cart.total.toLocaleString('id-ID')"></span>)
            </button>
          </div>
        </form>
      </div>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
