<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Clear client-side cart cache on success page load -->
<script>
  document.addEventListener('alpine:init', () => {
    localStorage.removeItem('resto_cart');
    Alpine.store('cart').clear();
  });
</script>

<div class="flex-grow flex items-center justify-center py-12 px-4">
  <div class="max-w-xl w-full relative">
    <!-- Glow Effect -->
    <div class="absolute inset-0 bg-emerald-500 rounded-3xl blur-3xl opacity-10"></div>
    
    <div class="relative glass-card border border-slate-700/50 rounded-3xl p-6 sm:p-8 shadow-2xl flex flex-col items-center text-center">
      
      <!-- Success Icon -->
      <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-3xl animate-bounce-subtle">
        <i class="fa-solid fa-circle-check"></i>
      </div>

      <h2 class="text-white text-2xl sm:text-3xl font-extrabold mb-2">Pesanan Berhasil Dikirim!</h2>
      <p class="text-slate-400 text-sm mb-6 max-w-sm">
        Terima kasih telah memesan di <%= settings.resto_name || 'Dermaga Seafood' %>. Pesanan Anda sedang diteruskan ke dapur kami.
      </p>

      <!-- Order Summary Card -->
      <div class="w-full bg-dark-900/60 border border-slate-800 rounded-2xl p-5 mb-8 text-left space-y-4 text-sm">
        <div class="flex justify-between items-center pb-3 border-b border-slate-800">
          <span class="text-slate-400">ID Pesanan</span>
          <span class="text-white font-bold">#<%= order.id %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-slate-400">Nama Pelanggan</span>
          <span class="text-slate-200 font-medium"><%= order.customerName %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-slate-400">Tipe Layanan</span>
          <span class="text-slate-200 font-medium capitalize">
            <%= order.type === 'dine-in' ? 'Makan di Sini' : 'Kirim (Delivery)' %>
          </span>
        </div>
        
        <% if (order.type === 'dine-in') { %>
          <div class="flex justify-between items-center">
            <span class="text-slate-400">Nomor Meja</span>
            <span class="text-slate-200 font-medium"><%= order.tableNumber %></span>
          </div>
        <% } else { %>
          <div class="flex justify-between items-start gap-4">
            <span class="text-slate-400 flex-shrink-0">Alamat Kirim</span>
            <span class="text-slate-200 font-medium text-right line-clamp-2"><%= order.address %></span>
          </div>
        <% } %>

        <div class="border-t border-slate-800 pt-3">
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Menu Pesanan</p>
          <ul class="space-y-1.5 max-h-40 overflow-y-auto">
            <% order.items.forEach(item => { %>
              <li class="flex justify-between text-slate-300 text-xs">
                <span>
                  <strong><%= item.quantity %> <%= item.menu.priceType === 'kg' ? 'Kg' : 'Pcs' %></strong> x <%= item.menu.name %>
                  <% if (item.notes) { %>
                    <span class="block text-[10px] text-slate-500 italic">Catatan: <%= item.notes %></span>
                  <% } %>
                </span>
                <span class="text-slate-100 font-semibold">
                  Rp <%= (parseFloat(item.price) * item.quantity).toLocaleString('id-ID') %>
                </span>
              </li>
            <% }) %>
          </ul>
        </div>

        <div class="flex justify-between items-center pt-3 border-t border-slate-800">
          <span class="text-slate-400 font-semibold">Total Pembayaran</span>
          <span class="text-brand-500 text-lg font-black">
            Rp <%= parseFloat(order.totalPrice).toLocaleString('id-ID') %>
          </span>
        </div>
      </div>

      <!-- QRIS Dynamic Payment Box -->
      <% if (typeof qrisData !== 'undefined' && qrisData) { %>
        <div class="w-full bg-dark-900/40 border border-slate-800 rounded-2xl p-6 mb-6 flex flex-col items-center justify-center space-y-4">
          <div class="text-center space-y-1">
            <h4 class="text-white font-bold text-sm uppercase tracking-wide">Bayar Langsung via QRIS</h4>
            <p class="text-slate-400 text-xs">Scan QR Code di bawah menggunakan E-Wallet atau M-Banking Anda</p>
          </div>
          
          <!-- QR Code Image -->
          <div class="bg-white p-3 rounded-2xl border border-slate-200 shadow-inner flex items-center justify-center">
            <img 
              src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=<%= encodeURIComponent(qrisData) %>" 
              alt="QRIS Dynamic QR Code" 
              class="w-48 h-48 object-contain"
            />
          </div>

          <div class="text-center">
            <span class="text-[10px] font-black text-brand-500 bg-brand-500/10 border border-brand-500/20 px-3 py-1 rounded-full uppercase tracking-wider">
              Nominal Terkunci: Rp <%= parseFloat(order.totalPrice).toLocaleString('id-ID') %>
            </span>
            <p class="text-[10px] text-slate-500 mt-2">QRIS ini bersifat dinamis. Nominal pembayaran sudah sesuai tagihan Anda.</p>
          </div>
        </div>
      <% } %>

      <!-- Action Buttons -->
      <div class="w-full flex flex-col gap-3">
        <!-- Send WA Button -->
        <a 
          href="<%= waLink %>" 
          target="_blank"
          class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3.5 rounded-xl font-bold transition flex items-center justify-center gap-2 shadow-lg shadow-emerald-600/20 hover:shadow-emerald-500/30"
        >
          <i class="fa-brands fa-whatsapp text-lg"></i> Kirim Notifikasi ke WhatsApp Resto
        </a>
        
        <!-- Waiter/Staff Actions -->
        <% if (typeof user !== 'undefined' && user) { %>
          <div class="flex gap-3">
            <a 
              href="/orders/<%= order.id %>/print" 
              target="_blank"
              class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-3.5 rounded-xl font-bold transition flex items-center justify-center gap-2 shadow-lg shadow-blue-600/20 cursor-pointer"
            >
              <i class="fa-solid fa-print"></i> Cetak Struk
            </a>
            <% const dashUrl = user.role === 'admin' ? '/admin/dashboard' : '/waiter/orders' %>
            <a 
              href="<%= dashUrl %>" 
              class="flex-1 bg-sky-600 hover:bg-sky-500 text-white py-3.5 rounded-xl font-bold transition flex items-center justify-center gap-2 shadow-lg shadow-sky-600/20 cursor-pointer"
            >
              <i class="fa-solid fa-gauge"></i> Ke Dashboard
            </a>
          </div>
        <% } %>

        <!-- Back to Home -->
        <a 
          href="/" 
          class="w-full bg-dark-800 hover:bg-dark-700 border border-slate-700 text-slate-300 py-3.5 rounded-xl font-bold transition flex items-center justify-center gap-2"
        >
          <i class="fa-solid fa-house"></i> Kembali ke Halaman Utama
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>
